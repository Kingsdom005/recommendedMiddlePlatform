# Kafka 配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# HBase 配置
HBASE_HOST=localhost
HBASE_PORT=9090

# Elasticsearch 配置
ES_HOST=http://localhost:9200

# 模型配置
MODEL_DIR=./model/models
